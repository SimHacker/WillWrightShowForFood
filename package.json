{
	"name": "willwrightshowforfood",
	"version": "0.1.0",
	"private": true,
	"description": "WillWrightShowForFood — polyglot MOOLLM microworld monorepo (Repo Show + apps + packages)",
	"type": "module",
	"scripts": {
		"build": "pnpm -r --stream --if-present run build",
		"test": "pnpm -r --stream --if-present run test",
		"verify:structure": "node scripts/verify-monorepo-structure.mjs",
		"verify:yaml": "node scripts/verify-yaml.mjs",
		"facades": "node scripts/generate-markup-facades.mjs --force",
		"facades:check": "node scripts/generate-markup-facades.mjs --check",
		"scaffold:characters": "node scripts/scaffold-invitation-characters.mjs",
		"scaffold:cards": "python3 scripts/scaffold-guest-skills-cards.py",
		"scaffold:skills-cards": "python3 scripts/scaffold-guest-skills-cards.py",
		"normalize:characters": "node scripts/normalize-guest-characters.mjs",
		"verify": "pnpm run verify:structure && pnpm run verify:yaml",
		"setup:python": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
		"setup:hooks": "sh scripts/install-git-hooks.sh"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
